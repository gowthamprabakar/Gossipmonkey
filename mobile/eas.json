{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": false,
                "resourceClass": "m-medium"
            },
            "android": {
                "buildType": "apk"
            },
            "env": {
                "APP_ENV": "development"
            }
        },
        "preview": {
            "distribution": "internal",
            "ios": {
                "resourceClass": "m-medium"
            },
            "android": {
                "buildType": "apk"
            },
            "env": {
                "APP_ENV": "preview"
            }
        },
        "production": {
            "autoIncrement": true,
            "ios": {
                "resourceClass": "m-medium"
            },
            "env": {
                "APP_ENV": "production"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleId": "your-apple-id@example.com",
                "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
                "appleTeamId": "YOUR_APPLE_TEAM_ID"
            }
        }
    }
}